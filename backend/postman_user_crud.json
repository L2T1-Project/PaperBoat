          "raw": "{\n  \"username\": \"ghostuser\",\n  \"full_name\": \"Ghost User\",\n  \"email\": \"ghost@example.com\",\n  \"password_hash\": \"$2b$10$examplehashedpassword\",\n  \"status_id\": 9999\n}",
