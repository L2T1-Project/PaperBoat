        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"johndoe_updated\",\n  \"full_name\": \"John Doe Updated\",\n  \"email\": \"johndoe_updated@example.com\",\n  \"phone_number\": \"+9876543210\",\n  \"profile_pic_url\": \"https://example.com/pics/johndoe.jpg\",\n  \"bio\": \"Updated bio: Senior researcher in NLP.\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/api/users/{{user_id}}",
          "host": ["{{base_url}}"],
          "path": ["api", "users", "{{user_id}}"]
        },
        "description": "Updates an existing user by ID. Required fields: username, full_name, email."
      },
      "response": []
    },
    {
      "name": "Delete User",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/users/{{user_id}}",
          "host": ["{{base_url}}"],
          "path": ["api", "users", "{{user_id}}"]
        },
        "description": "Deletes a user by ID. Returns the deleted user's id, username, full_name, and email."
      },
      "response": []
    },
    {
