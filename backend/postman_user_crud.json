          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"johndoe\",\n  \"full_name\": \"John Doe\",\n  \"email\": \"johndoe@example.com\",\n  \"password_hash\": \"$2b$10$examplehashedpassword\",\n  \"status_id\": 1\n}",
